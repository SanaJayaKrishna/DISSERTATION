<?xml version="1.0"?>
<robot name="mobile_manipulator_example">
  <material name="white">
    <color rgba="0.9 0.9 0.9 1"/>
  </material>
  <material name="black">
    <color rgba="0.02 0.02 0.02 1"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="0.55 0.42 0.24"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry>
        <box size="0.55 0.42 0.24"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <mass value="18.0"/>
      <inertia ixx="0.4" ixy="0" ixz="0" iyy="0.45" iyz="0" izz="0.55"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
  </link>
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.0 0.25 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="8" velocity="10"/>
  </joint>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.25 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="8" velocity="10"/>
  </joint>

  <link name="sensor_mast"/>
  <joint name="sensor_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mast"/>
    <origin xyz="0.12 0 0.32" rpy="0 0 0"/>
  </joint>
  <link name="rgbd_camera_link"/>
  <joint name="camera_mount_joint" type="fixed">
    <parent link="sensor_mast"/>
    <child link="rgbd_camera_link"/>
    <origin xyz="0.05 0 0.22" rpy="0 0 0"/>
  </joint>
  <link name="lidar_link"/>
  <joint name="lidar_mount_joint" type="fixed">
    <parent link="sensor_mast"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.28" rpy="0 0 0"/>
  </joint>

  <link name="shoulder_link"/>
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0.10 0 0.28" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="30" velocity="1.5"/>
  </joint>
  <link name="upper_arm_link"/>
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="30" velocity="1.5"/>
  </joint>
  <link name="forearm_link"/>
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.26 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.4" upper="2.4" effort="25" velocity="1.5"/>
  </joint>
  <link name="wrist_link"/>
  <joint name="wrist_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.24 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="15" velocity="2.0"/>
  </joint>
  <link name="parallel_gripper"/>
  <joint name="gripper_mount_joint" type="fixed">
    <parent link="wrist_link"/>
    <child link="parallel_gripper"/>
    <origin xyz="0.10 0 0" rpy="0 0 0"/>
  </joint>
  <link name="left_finger"/>
  <link name="right_finger"/>
  <joint name="left_finger_joint" type="prismatic">
    <parent link="parallel_gripper"/>
    <child link="left_finger"/>
    <origin xyz="0.05 0.03 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.04" effort="20" velocity="0.2"/>
  </joint>
  <joint name="right_finger_joint" type="prismatic">
    <parent link="parallel_gripper"/>
    <child link="right_finger"/>
    <origin xyz="0.05 -0.03 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="0.04" effort="20" velocity="0.2"/>
  </joint>

  <transmission name="left_wheel_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="left_wheel_joint"/>
    <actuator name="left_wheel_motor"/>
  </transmission>
  <transmission name="right_wheel_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="right_wheel_joint"/>
    <actuator name="right_wheel_motor"/>
  </transmission>
  <transmission name="arm_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="shoulder_pan_joint"/>
    <actuator name="joint_actuator"/>
  </transmission>

  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so"/>
    <plugin name="joint_trajectory_controller" filename="libgazebo_ros_joint_trajectory.so"/>
  </gazebo>
  <gazebo reference="rgbd_camera_link">
    <sensor name="rgbd_camera" type="depth"/>
  </gazebo>
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="ray"/>
  </gazebo>
</robot>
